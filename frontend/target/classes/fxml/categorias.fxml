<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.consuhelp.client.controller.CategoriaController"
            styleClass="tela-raiz"
            prefWidth="800" prefHeight="600">

    <!-- ── Cabeçalho ─────────────────────────────────────────────────────── -->
    <top>
        <VBox styleClass="cabecalho-categorias">
            <HBox alignment="CENTER_LEFT">
                <Button text="☰" styleClass="btn-menu" onAction="#onVoltar"/>
                <Label text="ConsuHelp" styleClass="titulo-app" HBox.hgrow="ALWAYS"/>
            </HBox>
            <Label text="Qual é o seu problema?" styleClass="titulo-categorias"/>
        </VBox>
    </top>

    <!-- ── Grid 2x3 de Categorias ───────────────────────────────────────── -->
    <center>
        <StackPane>
            <VBox spacing="20" alignment="CENTER">
                <padding><Insets top="30" right="60" bottom="30" left="60"/></padding>

                <!-- Linha 1 -->
                <HBox spacing="16" alignment="CENTER">
                    <Button text="📦  Produto danificado"
                            styleClass="btn-categoria"
                            onAction="#onProdutoDanificado"
                            maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                    <Button text="🚚  Produto não entregue"
                            styleClass="btn-categoria"
                            onAction="#onProdutoNaoEntregue"
                            maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                    <Button text="💳  Cobrança indevida"
                            styleClass="btn-categoria"
                            onAction="#onCobrancaIndevida"
                            maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                </HBox>

                <!-- Linha 2 -->
                <HBox spacing="16" alignment="CENTER">
                    <Button text="💰  Exigência de valor excessivo"
                            styleClass="btn-categoria"
                            onAction="#onExigenciaExcessiva"
                            maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                    <Button text="🛡️  Garantia não reconhecida"
                            styleClass="btn-categoria"
                            onAction="#onGarantiaNaoReconhecida"
                            maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                    <Button text="⚠️  Suspeita de golpe/fraude"
                            styleClass="btn-categoria"
                            onAction="#onSuspeitaGolpe"
                            maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                </HBox>

                <!-- Status de carregamento -->
                <Label fx:id="labelStatus" styleClass="label-status"
                       visible="false" wrapText="true"/>
            </VBox>
        </StackPane>
    </center>

    <!-- ── Rodapé: botão voltar ───────────────────────────────────────────── -->
    <bottom>
        <HBox styleClass="rodape-simples" alignment="CENTER_LEFT">
            <padding><Insets top="10" right="30" bottom="15" left="30"/></padding>
            <Button text="← Voltar" styleClass="btn-voltar" onAction="#onVoltar"/>
        </HBox>
    </bottom>
</BorderPane>
