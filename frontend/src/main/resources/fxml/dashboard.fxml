<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.consuhelp.client.controller.DashboardController"
            styleClass="tela-raiz"
            prefWidth="800" prefHeight="600">

    <!-- ── Cabeçalho ─────────────────────────────────────────────────────── -->
    <top>
        <HBox styleClass="cabecalho" alignment="CENTER_LEFT">
            <Button text="☰" styleClass="btn-menu" onAction="#onAbrirCategorias"/>
            <Label text="ConsuHelp" styleClass="titulo-app" HBox.hgrow="ALWAYS"/>
            <Button text="Sair" styleClass="btn-sair" onAction="#onLogout"/>
        </HBox>
    </top>

    <!-- ── Menu Lateral (esquerda) ───────────────────────────────────────── -->
    <left>
        <VBox styleClass="menu-lateral" spacing="12">
            <padding><Insets top="20" right="12" bottom="20" left="12"/></padding>
            <Label text="👤" styleClass="avatar-icone"/>
            <Label fx:id="labelBoasVindas" styleClass="label-usuario" wrapText="true"/>
        </VBox>
    </left>

    <!-- ── Área Central (histórico / informativo) ────────────────────────── -->
    <center>
        <StackPane styleClass="area-central">
            <VBox alignment="CENTER" spacing="12">
                <Label text="Como posso ajudar você hoje?" styleClass="titulo-dashboard"/>
                <Label text="Descreva seu problema abaixo ou escolha uma categoria no menu lateral."
                       styleClass="subtitulo-dashboard" wrapText="true"/>
                <Label fx:id="labelStatus" styleClass="label-status" wrapText="true" visible="false"/>
            </VBox>
        </StackPane>
    </center>

    <!-- ── Rodapé: barra de busca ────────────────────────────────────────── -->
    <bottom>
        <VBox styleClass="rodape-busca">
            <padding><Insets top="12" right="30" bottom="20" left="30"/></padding>
            <HBox spacing="8" alignment="CENTER">
                <TextField fx:id="campoBusca"
                           promptText="Informe o que deseja saber aqui"
                           styleClass="barra-busca"
                           HBox.hgrow="ALWAYS"
                           onAction="#onBuscar"/>
                <Button fx:id="botaoBuscar" text="🔍"
                        styleClass="btn-busca"
                        onAction="#onBuscar"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>
